prgx_dbt_models:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "<your_snowflake_account>"
      user: "<your_username>"
      password: "<your_password_or_use_env_var>"
      role: "<your_role>"
      database: "<your_database>"
      warehouse: "<your_warehouse>"
      schema: "<your_dev_schema>"
      threads: 4
